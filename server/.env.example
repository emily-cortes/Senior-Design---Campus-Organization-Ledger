PORT=3001
JWT_SECRET=replace-with-a-long-secret

# Comma-separated K-numbers that should be treated as admin accounts.
ADMIN_ACCOUNT_IDS=K00123456

# Firebase is optional for local prototype use.
# Provide either FIREBASE_SERVICE_ACCOUNT_PATH or FIREBASE_SERVICE_ACCOUNT_JSON
# to switch users, organizations, and transactions to Firestore.
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional Firestore collection overrides
# FIREBASE_USERS_COLLECTION=users
# FIREBASE_ORGANIZATIONS_COLLECTION=organizations
# FIREBASE_TRANSACTIONS_COLLECTION=transactions
# FIREBASE_ACCESS_ROLES_COLLECTION=access_roles
# FIREBASE_ACCESS_ASSIGNMENTS_COLLECTION=access_assignments
